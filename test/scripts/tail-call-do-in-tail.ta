// Test: tail-call-do-in-tail
// Purpose: (begin ...) in tail position should still be optimized
//          as a tail call. The inner expression of begin in tail
//          position is the actual tail. Counts down from 1000000 to 0.
// Expected output: 0

fn count(n) {
  if n == 0 {
    n
  } else {
    {
      count(n - 1)
    }
  }
}

fn main() {
  print(count(1000000))
}