// Test: closure-nested-capture
// Purpose: Three-level nested closure capturing different variables at
//          each level. Verifies closure free-vars are correctly copied
//          during GC and deep copy (spawn with closure).
// Expected output: 6

fn f(x) {
  fn(y) {
    fn(z) {
      x + (y + z)
    }
  }
}

fn main() {
  let g = f(1)
  let h = g(2)
  print(h(3))
}