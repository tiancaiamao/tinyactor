// Test: closure-curry
// Purpose: Partial application through currying. Exercises closure
//          creation with 0, 1, 2 args. Inspired by cora's curry.cora,
//          curry-as-arg.cora, curry-partial.cora.
// Expected output: 5

fn add(a, b) {
  a + b
}

fn curry(f, x) {
  fn(y) { f(x, y) }
}

fn main() {
  let g = curry(add, 3)
  print(g(2))
}