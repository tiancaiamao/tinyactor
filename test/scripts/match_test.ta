// Phase 1 test: basic match patterns
// Expected output: 1\n2\n3\n4

fn main() {
  match 42 {
    42 -> print(1)
    _ -> print(0)
  }

  match 'hello {
    'hello -> print(2)
    _ -> print(0)
  }

  match cons(1, 2) {
    cons(a, b) -> print(3)
    _ -> print(0)
  }

  match nil {
    nil -> print(4)
    _ -> print(0)
  }
}