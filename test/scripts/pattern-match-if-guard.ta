// Test: pattern-match-if-guard
// Purpose: Test if guard in pattern matching
// Expected: prints "positive\nzero_or_neg"

fn test_guard() {
  let x = 5
  match x {
    n if n > 0 -> print("positive")
    _ -> print("zero_or_neg")
  }
}

fn test_guard_false() {
  let x = -3
  match x {
    n if n > 0 -> print("positive")
    _ -> print("zero_or_neg")
  }
}

fn test_guard_var() {
  let x = 42
  match x {
    n if n == 42 -> print("is 42")
    _ -> print("not 42")
  }
}

fn main() {
  test_guard()
  test_guard_false()
  test_guard_var()
}