import tokenizer

fn print_tokens(toks) {
  if null?(toks) {
    print("PASS")
  } else {
    let t = car(toks)
    let typ = car(t)
    let val = cdr(t)
    print(typ)
    if string?(val) {
      print(val)
    } else {
      if int?(val) {
        print(val)
      } else {
        print("---")
      }
    }
    print_tokens(cdr(toks))
  }
}

fn main() {
  let src = "fn add(x) { x + 1 }"
  let toks = tokenizer.tokenize(src)
  print_tokens(toks)
}
