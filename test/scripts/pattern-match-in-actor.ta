// Test: pattern-match-in-actor
// Purpose: Actor uses pattern matching in its main recv loop.
//          Tests match + recv integration under concurrent execution.
// Expected output: pong\nping\ndone

fn server() {
  match recv() {
    cons('ping, from) -> {
      print("pong")
      send(from, 'pong)
      server()
    }
    'stop -> print("done")
  }
}

fn client(server_pid) {
  send(server_pid, cons('ping, self()))
  match recv() {
    'pong -> {
      print("ping")
      send(server_pid, 'stop)
    }
  }
}

fn main() {
  let srv = spawn('server)
  spawn(fn { client(srv) })
  let ref = monitor(srv)
  recv()
}