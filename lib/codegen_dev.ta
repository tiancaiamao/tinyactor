// codegen.ta — Self-hosted TA compiler: AST → .tabc bytecode
// Port of codegen.lisp, but uses TA's match for clean pattern-based dispatch.
//
// State = (fn_names . (next_fn_id . (fn_entries . (env . (next_slot . max_slot)))))
//   fn_names    = alist of (func_sym . fn_id) for top-level defines
//   next_fn_id  = next fn_id counter for lambda allocation
//   fn_entries  = alist of (fn_id . entry) for lambda/define function offsets
//   env         = alist of (var_sym . slot)
//   next_slot   = next available slot (negative)
//   max_slot    = minimum slot used (for ENTER calculation)

import buf
import str

// ============================================================
// Bytecode opcode constants (mirrors OpCode enum in ta.h)
// ============================================================

fn OP_PUSH_NIL() { 0 }
fn OP_PUSH_TRUE() { 1 }
fn OP_PUSH_FALSE() { 2 }
fn OP_PUSH_INT8() { 3 }
fn OP_PUSH_INT() { 4 }
fn OP_PUSH_SYM() { 5 }
fn OP_PUSH_STRING() { 6 }
fn OP_LOAD() { 7 }
fn OP_STORE() { 8 }
fn OP_CONS() { 9 }
fn OP_CAR() { 10 }
fn OP_CDR() { 11 }
fn OP_ADD() { 12 }
fn OP_SUB() { 13 }
fn OP_MUL() { 14 }
fn OP_DIV() { 15 }
fn OP_MOD() { 16 }
fn OP_EQ() { 17 }
fn OP_LT() { 18 }
fn OP_LE() { 19 }
fn OP_IS_NIL() { 20 }
fn OP_IS_PAIR() { 21 }
fn OP_IS_INT() { 22 }
fn OP_IS_STRING() { 23 }
fn OP_IS_BYTES() { 24 }
fn OP_IS_PID() { 25 }
fn OP_JUMP() { 26 }
fn OP_JUMP_IF_FALSE() { 27 }
fn OP_POP() { 28 }
fn OP_DUP() { 29 }
fn OP_CLOSURE() { 30 }
fn OP_CALL() { 31 }
fn OP_TAIL_CALL() { 32 }
fn OP_RET() { 33 }
fn OP_SPAWN() { 34 }
fn OP_SPAWN_MAIN() { 35 }
fn OP_SPAWN_CLOS() { 36 }
fn OP_SEND() { 37 }
fn OP_RECV() { 38 }
fn OP_RECV_PEEK() { 39 }
fn OP_RECV_COMMIT() { 40 }
fn OP_SELF() { 41 }
fn OP_MONITOR() { 42 }
fn OP_PRINT() { 43 }
fn OP_HALT() { 44 }
fn OP_MATCH_INT() { 45 }
fn OP_MATCH_SYM() { 46 }
fn OP_MATCH_NIL() { 47 }
fn OP_MATCH_PAIR() { 48 }
fn OP_MATCH_JUMP() { 49 }
fn OP_STR_LEN() { 50 }
fn OP_STR_CONCAT() { 51 }
fn OP_STR_SLICE() { 52 }
fn OP_STR_EQ() { 53 }
fn OP_CCALL() { 54 }
fn OP_ENTER() { 55 }

// ============================================================
// Byte emission helpers
// ============================================================

fn emit_u32(b, val) {
  let u = if val < 0 { val + 4294967296 } else { val }
  buf.push_byte(b, u % 256)
  buf.push_byte(b, (u / 256) % 256)
  buf.push_byte(b, (u / 65536) % 256)
  buf.push_byte(b, (u / 16777216) % 256)
}

fn emit_i64(b, val) {
  buf.push_byte(b, val % 256)
  buf.push_byte(b, (val / 256) % 256)
  buf.push_byte(b, (val / 65536) % 256)
  buf.push_byte(b, (val / 16777216) % 256)
  let hi = val / 4294967296
  buf.push_byte(b, hi % 256)
  buf.push_byte(b, (hi / 256) % 256)
  buf.push_byte(b, (hi / 65536) % 256)
  buf.push_byte(b, (hi / 16777216) % 256)
}

fn patch_u32(b, pos, val) {
  let u = if val < 0 { val + 4294967296 } else { val }
  buf.set_byte(b, pos, u % 256)
  buf.set_byte(b, pos + 1, (u / 256) % 256)
  buf.set_byte(b, pos + 2, (u / 65536) % 256)
  buf.set_byte(b, pos + 3, (u / 16777216) % 256)
}

fn patch_jumps(b, jumps, target) {
  match jumps {
    nil -> nil
    cons(j, rest) -> {
      patch_u32(b, j, target)
      patch_jumps(b, rest, target)
    }
  }
}

fn patch_all_jumps(b, jumps, addr) {
  match jumps {
    nil -> nil
    cons(j, rest) -> {
      patch_u32(b, j, addr)
      patch_all_jumps(b, rest, addr)
    }
  }
}

// ============================================================
// List helpers
// ============================================================

fn list_len(lst) {
  match lst {
    nil -> 0
    cons(_, rest) -> 1 + list_len(rest)
  }
}

fn list_ref(lst, n) {
  if n == 0 { car(lst) }
  else { list_ref(cdr(lst), n - 1) }
}

fn reverse_list(lst, acc) {
  match lst {
    nil -> acc
    cons(x, rest) -> reverse_list(rest, cons(x, acc))
  }
}

fn alist_find(lst, key) {
  match lst {
    nil -> nil
    cons(pair, rest) -> {
      if car(pair) == key { cdr(pair) }
      else { alist_find(rest, key) }
    }
  }
}

fn is_define_form(head) {
  if head == 'define { 1 }
  else {
    if head == 'define_pub { 1 }
    else { 0 }
  }
}

// ============================================================
// Symbol table management
// ============================================================

fn init_syms() {
  cons(cons("quote", 0), cons(cons("define", 1), cons(cons("lambda", 2),
  cons(cons("if", 3), cons(cons("begin", 4), cons(cons("let", 5),
  cons(cons("letrec", 6), cons(cons("match", 7), cons(cons("spawn", 8),
  cons(cons("send", 9), cons(cons("recv", 10), cons(cons("self", 11),
  cons(cons("monitor", 12), cons(cons("cons", 13), cons(cons("car", 14),
  cons(cons("cdr", 15), cons(cons("+", 16), cons(cons("-", 17),
  cons(cons("*", 18), cons(cons("/", 19), cons(cons("%", 20),
  cons(cons("=", 21), cons(cons("<", 22), cons(cons("<=", 23),
  cons(cons(">", 24), cons(cons(">=", 25), cons(cons("null?", 26),
  cons(cons("pair?", 27), cons(cons("int?", 28), cons(cons("string?", 29),
  cons(cons("bytes?", 30), cons(cons("pid?", 31), cons(cons("print", 32),
  cons(cons("true", 33), cons(cons("false", 34), cons(cons("DOWN", 35),
  cons(cons("nil", 36), cons(cons("_", 37), cons(cons("and", 38),
  cons(cons("or", 39), cons(cons("not", 40), cons(cons("set!", 41),
  nil))))))))))))))))))))))))))))))))))))))))))))
}

fn sym_count(syms) {
  match syms {
    nil -> 0
    cons(_, rest) -> 1 + sym_count(rest)
  }
}

fn sym_find_by_idx(syms, idx) {
  match syms {
    nil -> ""
    cons(pair, rest) -> {
      if cdr(pair) == idx { car(pair) }
      else { sym_find_by_idx(rest, idx) }
    }
  }
}

fn find_sym_index(syms, sym) {
  match syms {
    nil -> nil
    cons(pair, rest) -> {
      // sym is a lisp symbol, car(pair) is a string; convert sym to string for comparison
      if str.to_sym(car(pair)) == sym { cdr(pair) }
      else { find_sym_index(rest, sym) }
    }
  }
}

fn intern_ast_sym(syms, sym, next_idx) {
  let idx = find_sym_index(syms, sym)
  match idx {
    nil -> {
      let s = str.sym_to_str(sym)
      cons(cons(s, next_idx), cons(syms, next_idx + 1))
    }
    _ -> cons(syms, next_idx)
  }
}

fn embed_syms(fn_names, syms) {
  cons(cons('__syms__, syms), fn_names)
}

fn get_syms(fn_names) {
  let s = alist_find(fn_names, '__syms__)
  match s {
    nil -> init_syms()
    _ -> s
  }
}

fn collect_ast_syms(ast, syms, next_idx) {
  if null?(ast) { cons(syms, next_idx) }
  else if int?(ast) { cons(syms, next_idx) }
  else if string?(ast) { cons(syms, next_idx) }
  else if pair?(ast) {
    let r1 = collect_ast_syms(car(ast), syms, next_idx)
    collect_ast_syms(cdr(ast), car(r1), cdr(r1))
  }
  else if ast == true { cons(syms, next_idx) }
  else if ast == false { cons(syms, next_idx) }
  else { intern_ast_sym(syms, ast, next_idx) }
}

fn collect_ast_list(forms, syms, next_idx) {
  match forms {
    nil -> cons(syms, next_idx)
    cons(f, rest) -> {
      let r = collect_ast_syms(f, syms, next_idx)
      collect_ast_list(rest, car(r), cdr(r))
    }
  }
}

// ============================================================
// State management
// ============================================================

fn make_state(fn_names, next_fn_id, fn_entries, env, next_slot, max_slot) {
  cons(fn_names, cons(next_fn_id, cons(fn_entries,
    cons(env, cons(next_slot, max_slot)))))
}

fn st_fn_names(s) { car(s) }
fn st_next_fn_id(s) { car(cdr(s)) }
fn st_fn_entries(s) { car(cdr(cdr(s))) }
fn st_env(s) { car(cdr(cdr(cdr(s)))) }
fn st_next_slot(s) { car(cdr(cdr(cdr(cdr(s))))) }
fn st_max_slot(s) { cdr(cdr(cdr(cdr(cdr(s))))) }

// ============================================================
// Inline operator lookup
// ============================================================

fn inline_op(sym) {
  if sym == '+ { 12 }
  else if sym == '- { 13 }
  else if sym == '* { 14 }
  else if sym == '/ { 15 }
  else if sym == '% { 16 }
  else if sym == '= { 17 }
  else if sym == '< { 18 }
  else if sym == '<= { 19 }
  else if sym == '> { 18 }      // swapped: > uses OP_LT
  else if sym == '>= { 19 }     // swapped: >= uses OP_LE
  else if sym == 'cons { 9 }
  else if sym == 'car { 10 }
  else if sym == 'cdr { 11 }
  else if sym == 'null? { 20 }
  else if sym == 'pair? { 21 }
  else if sym == 'int? { 22 }
  else if sym == 'string? { 23 }
  else if sym == 'bytes? { 24 }
  else if sym == 'pid? { 25 }
  else if sym == 'print { 43 }
  else if sym == 'string-length { 50 }
  else if sym == 'string-concat { 51 }
  else if sym == 'string-slice { 52 }
  else if sym == 'string-eq { 53 }
  else { -1 }
}

fn is_swap_op(sym) {
  if sym == '> { 1 }
  else if sym == '>= { 1 }
  else { 0 }
}

fn is_symbol_val(v) {
  if int?(v) { 0 }
  else if string?(v) { 0 }
  else if pair?(v) { 0 }
  else if null?(v) { 0 }
  else { 1 }
}

// ============================================================
// Free variable collection
// ============================================================

fn fv_contains(fv, name) {
  match fv {
    nil -> 0
    cons(pair, rest) -> {
      if car(pair) == name { 1 }
      else { fv_contains(rest, name) }
    }
  }
}

fn fv_add(name, slot, fv) {
  if fv_contains(fv, name) == 1 { fv }
  else { cons(cons(name, slot), fv) }
}

fn is_param_sym(sym, params) {
  match params {
    nil -> 0
    cons(p, rest) -> {
      if p == sym { 1 }
      else { is_param_sym(sym, rest) }
    }
  }
}

fn filter_free_vars(fv, params) {
  match fv {
    nil -> nil
    cons(pair, rest) -> {
      if is_param_sym(car(pair), params) == 1 {
        filter_free_vars(rest, params)
      } else {
        cons(pair, filter_free_vars(rest, params))
      }
    }
  }
}

fn collect_free_vars(expr, env, acc) {
  if int?(expr) { acc }
  else if string?(expr) { acc }
  else if null?(expr) { acc }
  else if pair?(expr) {
    let head = car(expr)
    if is_symbol_val(head) == 1 {
      match head {
        'quote -> acc
        'define -> acc
        'lambda -> collect_free_body(cdr(cdr(expr)), env, acc)
        'if -> {
          let a1 = collect_free_vars(list_ref(expr, 1), env, acc)
          let a2 = collect_free_vars(list_ref(expr, 2), env, a1)
          collect_free_vars(list_ref(expr, 3), env, a2)
        }
        'begin -> collect_free_body(cdr(expr), env, acc)
        'let -> {
          let second = list_ref(expr, 1)
          if is_symbol_val(second) == 1 {
            let a1 = collect_free_vars(list_ref(expr, 2), env, acc)
            collect_free_body(cdr(cdr(cdr(expr))), env, a1)
          } else {
            if pair?(second) {
              collect_free_bindings(second, env, acc)
            } else {
              acc
            }
          }
        }
        'match -> {
          let a1 = collect_free_vars(list_ref(expr, 1), env, acc)
          collect_free_branches(cdr(cdr(expr)), env, a1)
        }
        'receive -> collect_free_branches(cdr(expr), env, acc)
        'receive-scan -> {
          let lam = list_ref(expr, 1)
          if is_symbol_val(lam) == 0 {
            collect_free_body(cdr(cdr(lam)), env, acc)
          } else { acc }
        }
        _ -> {
          let a0 = collect_free_vars(head, env, acc)
          collect_free_list(cdr(expr), env, a0)
        }
      }
    } else {
      collect_free_list(expr, env, acc)
    }
  }
  else {
    // symbol: check env, add if not bound
    if alist_find(env, expr) == nil {
      fv_add(expr, 0, acc)
    } else { acc }
  }
}

fn collect_free_list(expr, env, acc) {
  match expr {
    nil -> acc
    cons(x, rest) -> {
      let a1 = collect_free_vars(x, env, acc)
      collect_free_list(rest, env, a1)
    }
  }
}

fn collect_free_body(body, env, acc) {
  match body {
    nil -> acc
    cons(e, rest) -> {
      let a1 = collect_free_vars(e, env, acc)
      collect_free_body(rest, env, a1)
    }
  }
}

fn collect_free_bindings(bindings, env, acc) {
  match bindings {
    nil -> acc
    cons(b, rest) -> {
      // b = (var init)
      if pair?(b) && pair?(cdr(b)) {
        let a1 = collect_free_vars(list_ref(b, 1), env, acc)
        let a2 = collect_free_body(rest, env, a1)
        a2
      } else { acc }
    }
  }
}

fn collect_free_branches(branches, env, acc) {
  match branches {
    nil -> acc
    cons(branch, rest) -> {
      match branch {
        cons(_, body) -> {
          let a1 = collect_free_body(body, env, acc)
          collect_free_branches(rest, env, a1)
        }
        _ -> collect_free_branches(rest, env, acc)
      }
    }
  }
}

fn compute_free_vars(body, env, params) {
  let fv_raw = collect_free_body(body, env, nil)
  let fv_filtered = filter_free_vars(fv_raw, params)
  reverse_list(fv_filtered, nil)
}

// ============================================================
// Env building helpers
// ============================================================

fn build_param_env(params, slot) {
  match params {
    nil -> nil
    cons(p, rest) -> cons(cons(p, slot), build_param_env(rest, slot + 1))
  }
}

fn build_combined_env(params, slot, outer_env) {
  match params {
    nil -> outer_env
    cons(p, rest) -> cons(cons(p, slot), build_combined_env(rest, slot + 1, outer_env))
  }
}

fn add_free_vars_to_env(fv, slot, env) {
  match fv {
    nil -> env
    cons(pair, rest) -> {
      add_free_vars_to_env(rest, slot + 1,
        cons(cons(car(pair), slot), env))
    }
  }
}

fn build_body_env(params, free_vars) {
  build_body_env_loop(params, 0, free_vars)
}

fn build_body_env_loop(params, slot, free_vars) {
  match params {
    nil -> add_free_vars_to_env(free_vars, slot, nil)
    cons(p, rest) -> cons(cons(p, slot), build_body_env_loop(rest, slot + 1, free_vars))
  }
}

fn emit_free_slots(b, fv) {
  match fv {
    nil -> nil
    cons(pair, rest) -> {
      emit_u32(b, cdr(pair))
      emit_free_slots(b, rest)
    }
  }
}

// ============================================================
// rindex_dot: find last '.' in string (for module prefix resolution)
// ============================================================

fn rindex_dot(s, len) {
  if len == 0 { -1 }
  else {
    if str.char_at(s, len - 1) == 46 { len - 1 }
    else { rindex_dot(s, len - 1) }
  }
}

fn find_fn(fn_names, sym) {
  let direct = alist_find(fn_names, sym)
  match direct {
    nil -> {
      let s = str.sym_to_str(sym)
      let dot = rindex_dot(s, str.length(s))
      if dot == -1 { nil }
      else {
        let base = str.substr(s, dot + 1, str.length(s) - (dot + 1))
        let base_sym = str.to_sym(base)
        alist_find(fn_names, base_sym)
      }
    }
    _ -> direct
  }
}

// ============================================================
// Expression compilation helpers — pattern matching
// ============================================================

fn is_wildcard_sym(v) {
  if is_symbol_val(v) == 1 {
    if str.eq(str.sym_to_str(v), "_") == 1 { 1 }
    else { 0 }
  } else { 0 }
}

fn is_pattern_var(v) {
  if is_symbol_val(v) == 1 {
    if is_wildcard_sym(v) == 1 { 0 }
    else if str.eq(str.sym_to_str(v), "nil") == 1 { 0 }
    else if str.eq(str.sym_to_str(v), "cons") == 1 { 0 }
    else if str.eq(str.sym_to_str(v), "quote") == 1 { 0 }
    else { 1 }
  } else { 0 }
}

fn emit_match_pair(b, subj_slot, state, fail_jumps) {
  buf.push_byte(b, OP_LOAD())
  emit_u32(b, subj_slot)
  buf.push_byte(b, OP_MATCH_PAIR())
  buf.push_byte(b, OP_MATCH_JUMP())
  let jmp_pos = buf.length(b)
  emit_u32(b, 0)
  let new_fj = cons(jmp_pos, fail_jumps)
  let car_slot = st_next_slot(state)
  let cdr_slot = car_slot - 1
  let new_next = cdr_slot - 1
  buf.push_byte(b, OP_STORE())
  emit_u32(b, car_slot)
  buf.push_byte(b, OP_STORE())
  emit_u32(b, cdr_slot)
  let ms = st_max_slot(state)
  let new_ms = if new_next < ms { new_next } else { ms }
  let state2 = make_state(st_fn_names(state), st_next_fn_id(state),
                           st_fn_entries(state), st_env(state),
                           new_next, new_ms)
  cons(state2, cons(car_slot, cons(cdr_slot, new_fj)))
}

fn compile_list_pattern_loop(b, remaining, subj_slot, state, fail_jumps) {
  if null?(remaining) {
    buf.push_byte(b, OP_LOAD())
    emit_u32(b, subj_slot)
    buf.push_byte(b, OP_MATCH_NIL())
    buf.push_byte(b, OP_MATCH_JUMP())
    let jmp_pos = buf.length(b)
    emit_u32(b, 0)
    cons(state, cons(jmp_pos, fail_jumps))
  }
  else if is_symbol_val(remaining) == 1 {
    compile_pattern(b, remaining, subj_slot, state, fail_jumps)
  }
  else {
    let pr = emit_match_pair(b, subj_slot, state, fail_jumps)
    let state2 = car(pr)
    let car_slot = car(cdr(pr))
    let cdr_slot = car(cdr(cdr(pr)))
    let fj2 = cdr(cdr(cdr(pr)))
    let r1 = compile_pattern(b, car(remaining), car_slot, state2, fj2)
    compile_list_pattern_loop(b, cdr(remaining), cdr_slot, car(r1), cdr(r1))
  }
}

fn compile_pattern(b, pat, subj_slot, state, fail_jumps) {
  if is_wildcard_sym(pat) == 1 {
    cons(state, fail_jumps)
  }
  else if is_pattern_var(pat) == 1 {
    let var_slot = st_next_slot(state)
    buf.push_byte(b, OP_LOAD())
    emit_u32(b, subj_slot)
    buf.push_byte(b, OP_STORE())
    emit_u32(b, var_slot)
    let new_env = cons(cons(pat, var_slot), st_env(state))
    let new_next = var_slot - 1
    let ms = st_max_slot(state)
    let new_ms = if new_next < ms { new_next } else { ms }
    let state2 = make_state(st_fn_names(state), st_next_fn_id(state),
                             st_fn_entries(state), new_env,
                             new_next, new_ms)
    cons(state2, fail_jumps)
  }
  else if int?(pat) {
    buf.push_byte(b, OP_LOAD())
    emit_u32(b, subj_slot)
    buf.push_byte(b, OP_MATCH_INT())
    emit_i64(b, pat)
    buf.push_byte(b, OP_MATCH_JUMP())
    let jmp_pos = buf.length(b)
    emit_u32(b, 0)
    cons(state, cons(jmp_pos, fail_jumps))
  }
  else if null?(pat) {
    buf.push_byte(b, OP_LOAD())
    emit_u32(b, subj_slot)
    buf.push_byte(b, OP_MATCH_NIL())
    buf.push_byte(b, OP_MATCH_JUMP())
    let jmp_pos = buf.length(b)
    emit_u32(b, 0)
    cons(state, cons(jmp_pos, fail_jumps))
  }
  else if pair?(pat) {
    let head = car(pat)
    match head {
      'quote -> {
        let quoted = car(cdr(pat))
        if is_symbol_val(quoted) == 1 {
          buf.push_byte(b, OP_LOAD())
          emit_u32(b, subj_slot)
          buf.push_byte(b, OP_MATCH_SYM())
          let idx = find_sym_index(get_syms(st_fn_names(state)), quoted)
          match idx {
            nil -> emit_u32(b, 0)
            _ -> emit_u32(b, idx)
          }
          buf.push_byte(b, OP_MATCH_JUMP())
          let jmp_pos = buf.length(b)
          emit_u32(b, 0)
          cons(state, cons(jmp_pos, fail_jumps))
        } else {
          cons(state, fail_jumps)
        }
      }
      'nil -> {
        buf.push_byte(b, OP_LOAD())
        emit_u32(b, subj_slot)
        buf.push_byte(b, OP_MATCH_NIL())
        buf.push_byte(b, OP_MATCH_JUMP())
        let jmp_pos = buf.length(b)
        emit_u32(b, 0)
        cons(state, cons(jmp_pos, fail_jumps))
      }
      'cons -> {
        let pr = emit_match_pair(b, subj_slot, state, fail_jumps)
        let state2 = car(pr)
        let car_slot = car(cdr(pr))
        let cdr_slot = car(cdr(cdr(pr)))
        let fj2 = cdr(cdr(cdr(pr)))
        let pat_a = car(cdr(pat))
        let pat_b = car(cdr(cdr(pat)))
        let r1 = compile_pattern(b, pat_a, car_slot, state2, fj2)
        compile_pattern(b, pat_b, cdr_slot, car(r1), cdr(r1))
      }
      _ -> compile_list_pattern_loop(b, pat, subj_slot, state, fail_jumps)
    }
  }
  else {
    cons(state, fail_jumps)
  }
}

// ============================================================
// Expression compilation
// ============================================================

fn compile_expr(b, expr, tail, state) {
  if int?(expr) {
    if expr >= 0 {
      if expr < 256 {
        buf.push_byte(b, OP_PUSH_INT8())
        buf.push_byte(b, expr)
      } else {
        buf.push_byte(b, OP_PUSH_INT())
        emit_i64(b, expr)
      }
    } else {
      buf.push_byte(b, OP_PUSH_INT())
      emit_i64(b, expr)
    }
    state
  }
  else if string?(expr) {
    buf.push_byte(b, OP_PUSH_STRING())
    emit_u32(b, str.length(expr))
    buf.push_string(b, expr)
    state
  }
  else if pair?(expr) {
    compile_list(b, expr, tail, state)
  }
  else if null?(expr) {
    buf.push_byte(b, OP_PUSH_NIL())
    state
  }
  else if expr == true {
    buf.push_byte(b, OP_PUSH_TRUE())
    state
  }
  else if expr == false {
    buf.push_byte(b, OP_PUSH_FALSE())
    state
  }
  else {
    // symbol: check env, then fn_names (top-level function reference)
    let env = st_env(state)
    let slot = alist_find(env, expr)
    match slot {
      nil -> {
        let fn_names = st_fn_names(state)
        let fid = find_fn(fn_names, expr)
        match fid {
          nil -> {
            buf.push_byte(b, OP_PUSH_NIL())
            state
          }
          _ -> {
            buf.push_byte(b, OP_CLOSURE())
            emit_u32(b, fid)
            emit_u32(b, 0)
            state
          }
        }
      }
      _ -> {
        buf.push_byte(b, OP_LOAD())
        emit_u32(b, slot)
        state
      }
    }
  }
}

fn compile_list(b, expr, tail, state) {
  let head = car(expr)
  match head {
    'if -> compile_if(b, cdr(expr), tail, state)
    'let -> compile_let(b, cdr(expr), tail, state)
    'begin -> compile_begin(b, cdr(expr), tail, state)
    'lambda -> compile_lambda(b, cdr(expr), state)
    'and -> compile_and(b, cdr(expr), tail, state)
    'or -> compile_or(b, cdr(expr), tail, state)
    'quote -> compile_quote(b, cdr(expr), state)
    'define -> { buf.push_byte(b, OP_PUSH_NIL()); state }
    'define_pub -> { buf.push_byte(b, OP_PUSH_NIL()); state }
    'import -> { buf.push_byte(b, OP_PUSH_NIL()); state }
    'type -> { buf.push_byte(b, OP_PUSH_NIL()); state }
    'type-sig -> { buf.push_byte(b, OP_PUSH_NIL()); state }
    'receive-scan -> compile_receive_scan(b, cdr(expr), tail, state)
    _ -> compile_special(b, head, cdr(expr), tail, state)
  }
}

fn compile_special(b, head, args, tail, state) {
  match head {
    'spawn -> compile_spawn(b, args, state)
    'send -> compile_send(b, args, state)
    'recv -> { buf.push_byte(b, OP_RECV()); state }
    'self -> { buf.push_byte(b, OP_SELF()); state }
    'monitor -> {
      let s1 = compile_expr(b, car(args), 0, state)
      buf.push_byte(b, OP_MONITOR())
      s1
    }
    'match -> compile_match(b, args, tail, state)
    'receive -> compile_receive(b, args, tail, state)
    _ -> compile_general_call(b, head, args, tail, state)
  }
}

// ============================================================
// (if cond then else?)
// ============================================================

fn compile_if(b, args, tail, state) {
  let s1 = compile_expr(b, car(args), 0, state)
  buf.push_byte(b, OP_JUMP_IF_FALSE())
  let jif_pos = buf.length(b)
  emit_u32(b, 0)
  let n = list_len(args)
  let s2 = compile_expr(b, car(cdr(args)), tail, s1)
  if n >= 3 {
    buf.push_byte(b, OP_JUMP())
    let j_pos = buf.length(b)
    emit_u32(b, 0)
    let else_start = buf.length(b)
    patch_u32(b, jif_pos, else_start)
    let s3 = compile_expr(b, car(cdr(cdr(args))), tail, s2)
    patch_u32(b, j_pos, buf.length(b))
    s3
  } else {
    patch_u32(b, jif_pos, buf.length(b))
    buf.push_byte(b, OP_PUSH_NIL())
    s2
  }
}

// ============================================================
// (let var init body...) or (let ((v e)...) body...)
// ============================================================

fn compile_let(b, args, tail, state) {
  let second = car(args)
  if is_symbol_val(second) == 1 {
    compile_let_single(b, second, car(cdr(args)), cdr(cdr(args)), tail, state)
  } else {
    if null?(second) {
      compile_body(b, cdr(args), tail, state)
    } else {
      compile_let_multi(b, second, cdr(args), tail, state)
    }
  }
}

fn compile_let_single(b, var, init, body, tail, state) {
  let s1 = compile_expr(b, init, 0, state)
  let ns = st_next_slot(s1)
  let ms = st_max_slot(s1)
  let new_ms = if ns - 1 < ms { ns - 1 } else { ms }
  buf.push_byte(b, OP_STORE())
  emit_u32(b, ns)
  let new_env = cons(cons(var, ns), st_env(s1))
  compile_body(b, body, tail,
    make_state(st_fn_names(s1), st_next_fn_id(s1),
               st_fn_entries(s1), new_env, ns - 1, new_ms))
}

fn compile_let_multi(b, bindings, body, tail, state) {
  match bindings {
    nil -> compile_body(b, body, tail, state)
    cons(binding, rest) -> {
      match binding {
        cons(vname, cons(init_expr, _)) -> {
          let s1 = compile_expr(b, init_expr, 0, state)
          let ns = st_next_slot(s1)
          let ms = st_max_slot(s1)
          let new_ms = if ns - 1 < ms { ns - 1 } else { ms }
          buf.push_byte(b, OP_STORE())
          emit_u32(b, ns)
          let new_env = cons(cons(vname, ns), st_env(s1))
          compile_let_multi(b, rest, body, tail,
            make_state(st_fn_names(s1), st_next_fn_id(s1),
                       st_fn_entries(s1), new_env, ns - 1, new_ms))
        }
        _ -> compile_let_multi(b, rest, body, tail, state)
      }
    }
  }
}

// ============================================================
// (begin e1 e2 ... eN)
// ============================================================

fn compile_begin(b, args, tail, state) {
  match args {
    nil -> { buf.push_byte(b, OP_PUSH_NIL()); state }
    _ -> compile_begin_loop(b, args, tail, state)
  }
}

fn compile_begin_loop(b, args, tail, state) {
  match cdr(args) {
    nil -> compile_expr(b, car(args), tail, state)
    _ -> {
      let s1 = compile_expr(b, car(args), 0, state)
      buf.push_byte(b, OP_POP())
      compile_begin_loop(b, cdr(args), tail, s1)
    }
  }
}

// ============================================================
// (and e1 e2 ... eN) — short-circuit
// ============================================================

fn compile_and(b, args, tail, state) {
  if null?(args) { buf.push_byte(b, OP_PUSH_TRUE()); state }
  else if null?(cdr(args)) { compile_expr(b, car(args), tail, state) }
  else { compile_and_loop(b, args, tail, state, nil) }
}

fn compile_and_loop(b, args, tail, state, jumps) {
  match cdr(args) {
    nil -> {
      let s = compile_expr(b, car(args), tail, state)
      patch_jumps(b, jumps, buf.length(b))
      s
    }
    _ -> {
      let s = compile_expr(b, car(args), 0, state)
      buf.push_byte(b, OP_DUP())
      buf.push_byte(b, OP_JUMP_IF_FALSE())
      let jpos = buf.length(b)
      emit_u32(b, 0)
      buf.push_byte(b, OP_POP())
      compile_and_loop(b, cdr(args), tail, s, cons(jpos, jumps))
    }
  }
}

// ============================================================
// (or e1 e2 ... eN) — short-circuit
// ============================================================

fn compile_or(b, args, tail, state) {
  if null?(args) { buf.push_byte(b, OP_PUSH_NIL()); state }
  else if null?(cdr(args)) { compile_expr(b, car(args), tail, state) }
  else { compile_or_loop(b, args, tail, state, nil) }
}

fn compile_or_loop(b, args, tail, state, end_jumps) {
  match cdr(args) {
    nil -> {
      let s = compile_expr(b, car(args), tail, state)
      patch_jumps(b, end_jumps, buf.length(b))
      s
    }
    _ -> {
      let s = compile_expr(b, car(args), 0, state)
      buf.push_byte(b, OP_DUP())
      buf.push_byte(b, OP_JUMP_IF_FALSE())
      let patch_next = buf.length(b)
      emit_u32(b, 0)
      buf.push_byte(b, OP_JUMP())
      let end_pos = buf.length(b)
      emit_u32(b, 0)
      patch_u32(b, patch_next, buf.length(b))
      buf.push_byte(b, OP_POP())
      compile_or_loop(b, cdr(args), tail, s, cons(end_pos, end_jumps))
    }
  }
}

// ============================================================
// (quote x)
// ============================================================

fn compile_quote(b, args, state) {
  let quoted = car(args)
  if null?(quoted) {
    buf.push_byte(b, OP_PUSH_NIL())
    state
  }
  else if int?(quoted) {
    if quoted >= 0 {
      if quoted < 128 {
        buf.push_byte(b, OP_PUSH_INT8())
        buf.push_byte(b, quoted)
      } else {
        buf.push_byte(b, OP_PUSH_INT())
        emit_i64(b, quoted)
      }
    } else {
      if quoted >= -128 {
        buf.push_byte(b, OP_PUSH_INT8())
        buf.push_byte(b, quoted + 256)
      } else {
        buf.push_byte(b, OP_PUSH_INT())
        emit_i64(b, quoted)
      }
    }
    state
  }
  else if pair?(quoted) {
    buf.push_byte(b, OP_PUSH_NIL())
    state
  }
  else {
    let idx = find_sym_index(get_syms(st_fn_names(state)), quoted)
    match idx {
      nil -> { buf.push_byte(b, OP_PUSH_NIL()); state }
      _ -> {
        buf.push_byte(b, OP_PUSH_SYM())
        emit_u32(b, idx)
        state
      }
    }
  }
}

// ============================================================
// (lambda (params...) body...)
// ============================================================

fn compile_lambda(b, args, state) {
  let params = car(args)
  let body = cdr(args)
  let fn_names = st_fn_names(state)
  let next_fn_id = st_next_fn_id(state)
  let fn_entries = st_fn_entries(state)
  let env = st_env(state)
  let combined_env = build_combined_env(params, 0, env)
  let free_vars = compute_free_vars(body, combined_env, params)
  let nfree = list_len(free_vars)
  buf.push_byte(b, OP_CLOSURE())
  emit_u32(b, next_fn_id)
  emit_u32(b, nfree)
  emit_free_slots(b, free_vars)
  buf.push_byte(b, OP_JUMP())
  let jump_pos = buf.length(b)
  emit_u32(b, 0)
  let entry = buf.length(b)
  let body_env = build_body_env(params, free_vars)
  buf.push_byte(b, OP_ENTER())
  let enter_pos = buf.length(b)
  emit_u32(b, 0)
  let body_state = make_state(fn_names, next_fn_id + 1,
      cons(cons(next_fn_id, entry), fn_entries),
      body_env, -5, -5)
  let fs = compile_body(b, body, 1, body_state)
  buf.push_byte(b, OP_RET())
  patch_u32(b, enter_pos, (-5) - st_max_slot(fs))
  patch_u32(b, jump_pos, buf.length(b))
  make_state(fn_names, st_next_fn_id(fs),
             st_fn_entries(fs),
             env, st_next_slot(state), st_max_slot(state))
}

// ============================================================
// Function call compilation
// ============================================================

fn compile_call(b, head, args, tail, state) {
  let op = inline_op(head)
  if op >= 0 {
    let s1 = compile_args(b, args, state)
    buf.push_byte(b, op)
    s1
  }
  else if is_swap_op(head) == 1 {
    // > uses OP_LT with swapped operands, >= uses OP_LE with swapped operands
    let swap_op = if head == '> { OP_LT() } else { OP_LE() }
    let s1 = compile_expr(b, list_ref(args, 1), 0, state)
    let s2 = compile_expr(b, list_ref(args, 0), 0, s1)
    buf.push_byte(b, swap_op)
    s2
  }
  else if is_symbol_val(head) == 1 {
    let cfidx = vm.cfunc_index(head)
    if cfidx >= 0 {
      let s1 = compile_args(b, args, state)
      buf.push_byte(b, OP_CCALL())
      emit_u32(b, cfidx)
      s1
    } else {
      let fn_names = st_fn_names(state)
      let fid = find_fn(fn_names, head)
      match fid {
        nil -> {
          // fallback: treat as function expression
          let s1 = compile_expr(b, head, 0, state)
          let s2 = compile_args(b, args, s1)
          if tail == 1 { buf.push_byte(b, OP_TAIL_CALL()) }
          else { buf.push_byte(b, OP_CALL()) }
          emit_u32(b, list_len(args))
          s2
        }
        _ -> {
          buf.push_byte(b, OP_CLOSURE())
          emit_u32(b, fid)
          emit_u32(b, 0)
          let s1 = compile_args(b, args, state)
          if tail == 1 { buf.push_byte(b, OP_TAIL_CALL()) }
          else { buf.push_byte(b, OP_CALL()) }
          emit_u32(b, list_len(args))
          s1
        }
      }
    }
  } else {
    let s1 = compile_expr(b, head, 0, state)
    let s2 = compile_args(b, args, s1)
    if tail == 1 { buf.push_byte(b, OP_TAIL_CALL()) }
    else { buf.push_byte(b, OP_CALL()) }
    emit_u32(b, list_len(args))
    s2
  }
}

fn compile_spawn(b, args, state) {
  let arg0 = car(args)
  if pair?(arg0) {
    match car(arg0) {
      'quote -> {
        let quoted = car(cdr(arg0))
        if is_symbol_val(quoted) == 1 {
          let fid_raw = find_fn(st_fn_names(state), quoted)
          let fid = match fid_raw { nil -> 0; _ -> fid_raw }
          buf.push_byte(b, OP_SPAWN())
          emit_u32(b, fid)
          state
        } else {
          let s1 = compile_expr(b, arg0, 0, state)
          buf.push_byte(b, OP_SPAWN_CLOS())
          s1
        }
      }
      _ -> {
        let s1 = compile_expr(b, arg0, 0, state)
        buf.push_byte(b, OP_SPAWN_CLOS())
        s1
      }
    }
  } else {
    let s1 = compile_expr(b, arg0, 0, state)
    buf.push_byte(b, OP_SPAWN_CLOS())
    s1
  }
}

fn compile_send(b, args, state) {
  // compile.c: compile msg, compile pid, OP_SEND
  let s1 = compile_expr(b, car(cdr(args)), 0, state)
  let s2 = compile_expr(b, car(args), 0, s1)
  buf.push_byte(b, OP_SEND())
  s2
}

fn compile_general_call(b, head, args, tail, state) {
  let s1 = compile_expr(b, head, 0, state)
  let s2 = compile_args(b, args, s1)
  if tail == 1 { buf.push_byte(b, OP_TAIL_CALL()) }
  else { buf.push_byte(b, OP_CALL()) }
  emit_u32(b, list_len(args))
  s2
}

fn compile_args(b, args, state) {
  match args {
    nil -> state
    cons(a, rest) -> {
      let s1 = compile_expr(b, a, 0, state)
      compile_args(b, rest, s1)
    }
  }
}

// ============================================================
// receive-scan
// (receive-scan (lambda (msg) body...))
// ============================================================

fn compile_receive_scan(b, args, tail, state) {
  let lam = car(args)
  let params = car(cdr(lam))
  let body = cdr(cdr(lam))
  let msg_sym = car(params)
  let ns = st_next_slot(state)
  let ms = st_max_slot(state)
  let new_ms = if ns - 1 < ms { ns - 1 } else { ms }
  let loop_start = buf.length(b)
  buf.push_byte(b, OP_RECV_PEEK())
  buf.push_byte(b, OP_STORE())
  emit_u32(b, ns)
  let new_env = cons(cons(msg_sym, ns), st_env(state))
  let body_state = make_state(st_fn_names(state), st_next_fn_id(state),
                               st_fn_entries(state), new_env,
                               ns - 1, new_ms)
  let fs = compile_body(b, body, 0, body_state)
  buf.push_byte(b, OP_JUMP())
  emit_u32(b, loop_start)
  fs
}

// ============================================================
// receive { arms }
// ============================================================

fn compile_receive_branches(b, branches, tail, state, subj_slot, loop_start, end_jumps) {
  match branches {
    nil -> {
      buf.push_byte(b, OP_JUMP())
      emit_u32(b, loop_start)
      patch_all_jumps(b, end_jumps, buf.length(b))
      state
    }
    cons(branch, rest) -> {
      match branch {
        cons(pat, body) -> {
          let saved_slot = st_next_slot(state)
          let saved_env = st_env(state)
          let pj = compile_pattern(b, pat, subj_slot, state, nil)
          let state2 = car(pj)
          let fail_jumps = cdr(pj)
          buf.push_byte(b, OP_RECV_COMMIT())
          let s3 = compile_body(b, body, tail, state2)
          buf.push_byte(b, OP_JUMP())
          let jmp_pos = buf.length(b)
          emit_u32(b, 0)
          patch_all_jumps(b, fail_jumps, buf.length(b))
          let state3 = make_state(st_fn_names(s3), st_next_fn_id(s3),
                                   st_fn_entries(s3), saved_env,
                                   saved_slot, st_max_slot(s3))
          compile_receive_branches(b, rest, tail, state3, subj_slot,
            loop_start, cons(jmp_pos, end_jumps))
        }
        _ -> compile_receive_branches(b, rest, tail, state, subj_slot, loop_start, end_jumps)
      }
    }
  }
}

fn compile_receive(b, args, tail, state) {
  let branches = args
  let subj_slot = st_next_slot(state)
  let new_next = subj_slot - 1
  let ms = st_max_slot(state)
  let new_ms = if new_next < ms { new_next } else { ms }
  let state2 = make_state(st_fn_names(state), st_next_fn_id(state),
                           st_fn_entries(state), st_env(state),
                           new_next, new_ms)
  let loop_start = buf.length(b)
  buf.push_byte(b, OP_RECV_PEEK())
  buf.push_byte(b, OP_STORE())
  emit_u32(b, subj_slot)
  compile_receive_branches(b, branches, tail, state2, subj_slot, loop_start, nil)
}

// ============================================================
// match
// ============================================================

fn compile_match_branches(b, branches, tail, state, subj_slot, end_jumps) {
  match branches {
    nil -> {
      buf.push_byte(b, OP_PUSH_NIL())
      patch_all_jumps(b, end_jumps, buf.length(b))
      state
    }
    cons(branch, rest) -> {
      match branch {
        cons(pat, body) -> {
          let saved_slot = st_next_slot(state)
          let saved_env = st_env(state)
          let pj = compile_pattern(b, pat, subj_slot, state, nil)
          let state2 = car(pj)
          let fail_jumps = cdr(pj)
          let s3 = compile_body(b, body, tail, state2)
          buf.push_byte(b, OP_JUMP())
          let jmp_pos = buf.length(b)
          emit_u32(b, 0)
          patch_all_jumps(b, fail_jumps, buf.length(b))
          let state3 = make_state(st_fn_names(s3), st_next_fn_id(s3),
                                   st_fn_entries(s3), saved_env,
                                   saved_slot, st_max_slot(s3))
          compile_match_branches(b, rest, tail, state3, subj_slot,
            cons(jmp_pos, end_jumps))
        }
        _ -> compile_match_branches(b, rest, tail, state, subj_slot, end_jumps)
      }
    }
  }
}

fn compile_match(b, args, tail, state) {
  let scrutinee = car(args)
  let branches = cdr(args)
  let s1 = compile_expr(b, scrutinee, 0, state)
  let subj_slot = st_next_slot(s1)
  buf.push_byte(b, OP_STORE())
  emit_u32(b, subj_slot)
  let new_next = subj_slot - 1
  let ms = st_max_slot(s1)
  let new_ms = if new_next < ms { new_next } else { ms }
  let s2 = make_state(st_fn_names(s1), st_next_fn_id(s1), st_fn_entries(s1),
                       st_env(s1), new_next, new_ms)
  compile_match_branches(b, branches, tail, s2, subj_slot, nil)
}

// ============================================================
// Body compilation
// ============================================================

fn compile_body(b, body, tail, state) {
  if null?(body) { buf.push_byte(b, OP_PUSH_NIL()); state }
  else if null?(cdr(body)) { compile_expr(b, car(body), tail, state) }
  else {
    let s1 = compile_expr(b, car(body), 0, state)
    buf.push_byte(b, OP_POP())
    compile_body(b, cdr(body), tail, s1)
  }
}

// ============================================================
// Define body compilation
// ============================================================

fn compile_define_body(b, fn_names, next_fn_id, fn_entries, sig, body) {
  let param_env = build_param_env(cdr(sig), 0)
  buf.push_byte(b, OP_ENTER())
  let enter_pos = buf.length(b)
  emit_u32(b, 0)
  let init_state = make_state(fn_names, next_fn_id, fn_entries, param_env, -5, -5)
  let fs = compile_body(b, body, 1, init_state)
  buf.push_byte(b, OP_RET())
  patch_u32(b, enter_pos, (-5) - st_max_slot(fs))
  fs
}

// ============================================================
// Pass 1: register function names
// ============================================================

fn pass1_register(forms, acc, next_id) {
  match forms {
    nil -> cons(acc, next_id)
    cons(form, rest) -> {
      if pair?(form) {
        let head = car(form)
        if is_define_form(head) == 1 {
          let sig = car(cdr(form))
          if pair?(sig) {
            pass1_register(rest, cons(cons(car(sig), next_id), acc), next_id + 1)
          } else { pass1_register(rest, acc, next_id) }
        } else { pass1_register(rest, acc, next_id) }
      } else { pass1_register(rest, acc, next_id) }
    }
  }
}

// ============================================================
// Pass 2: compile function bodies
// ============================================================

fn pass2_compile(forms, b, fn_names, next_fn_id, fn_entries, cur_id, acc) {
  match forms {
    nil -> cons(next_fn_id, cons(fn_entries, acc))
    cons(form, rest) -> {
      if pair?(form) {
        let head = car(form)
        if is_define_form(head) == 1 {
          let sig = car(cdr(form))
          if pair?(sig) {
            let entry = buf.length(b)
            let fs = compile_define_body(b, fn_names, next_fn_id, fn_entries, sig, cdr(cdr(form)))
            pass2_compile(rest, b, fn_names,
              st_next_fn_id(fs), st_fn_entries(fs),
              cur_id + 1, cons(cons(cur_id, entry), acc))
          } else { pass2_compile(rest, b, fn_names, next_fn_id, fn_entries, cur_id, acc) }
        } else { pass2_compile(rest, b, fn_names, next_fn_id, fn_entries, cur_id, acc) }
      } else { pass2_compile(rest, b, fn_names, next_fn_id, fn_entries, cur_id, acc) }
    }
  }
}

// ============================================================
// Lookup helpers
// ============================================================

fn find_fn_offset(offsets, fn_id) {
  match offsets {
    nil -> 0
    cons(pair, rest) -> {
      if car(pair) == fn_id { cdr(pair) }
      else { find_fn_offset(rest, fn_id) }
    }
  }
}

fn find_fn_entry(define_offsets, lambda_offsets, fn_id) {
  let off = find_fn_offset(define_offsets, fn_id)
  if off > 0 { off }
  else { find_fn_offset(lambda_offsets, fn_id) }
}

fn find_main_fn(fn_names) {
  match fn_names {
    nil -> -1
    cons(pair, rest) -> {
      if car(pair) == 'main { cdr(pair) }
      else { find_main_fn(rest) }
    }
  }
}

// ============================================================
// Top-level expression compilation (non-define forms at top level)
// ============================================================

fn compile_top_level(forms, b, fn_names, fn_entries, next_fn_id, has_top) {
  match forms {
    nil -> cons(has_top, cons(fn_entries, next_fn_id))
    cons(form, rest) -> {
      if pair?(form) {
        let head = car(form)
        match head {
          'define -> compile_top_level(rest, b, fn_names, fn_entries, next_fn_id, has_top)
          'define_pub -> compile_top_level(rest, b, fn_names, fn_entries, next_fn_id, has_top)
          'import -> compile_top_level(rest, b, fn_names, fn_entries, next_fn_id, has_top)
          'const -> compile_top_level(rest, b, fn_names, fn_entries, next_fn_id, has_top)
          'type -> compile_top_level(rest, b, fn_names, fn_entries, next_fn_id, has_top)
          'type-sig -> compile_top_level(rest, b, fn_names, fn_entries, next_fn_id, has_top)
          _ -> {
            let s1 = compile_expr(b, form, 0,
              make_state(fn_names, next_fn_id, fn_entries, nil, 0, 0))
            buf.push_byte(b, OP_POP())
            compile_top_level(rest, b, fn_names,
              st_fn_entries(s1), st_next_fn_id(s1), 1)
          }
        }
      } else {
        compile_top_level(rest, b, fn_names, fn_entries, next_fn_id, has_top)
      }
    }
  }
}

// ============================================================
// Const support
// ============================================================

fn collect_consts(forms, acc) {
  match forms {
    nil -> acc
    cons(form, rest) -> {
      if pair?(form) {
        if car(form) == 'const {
          let name = car(cdr(form))
          let val_expr = car(cdr(cdr(form)))
          collect_consts(rest, cons(cons(name, val_expr), acc))
        } else { collect_consts(rest, acc) }
      } else { collect_consts(rest, acc) }
    }
  }
}

fn assq_key(key, alist) {
  match alist {
    nil -> nil
    cons(pair, rest) -> {
      if car(pair) == key { pair }
      else { assq_key(key, rest) }
    }
  }
}

fn resolve_consts(ast, consts) {
  if pair?(ast) {
    if car(ast) == 'quote {
      let inner = car(cdr(ast))
      if is_symbol_val(inner) == 1 {
        let pair = assq_key(inner, consts)
        match pair {
          nil -> ast
          _ -> cdr(pair)
        }
      } else { ast }
    } else {
      cons(resolve_consts(car(ast), consts), resolve_consts(cdr(ast), consts))
    }
  }
  else if is_symbol_val(ast) == 1 {
    let pair = assq_key(ast, consts)
    match pair {
      nil -> ast
      _ -> cdr(pair)
    }
  }
  else { ast }
}

fn resolve_const_values(consts, all_consts) {
  match consts {
    nil -> nil
    cons(entry, rest) -> {
      let name = car(entry)
      let value = cdr(entry)
      let resolved_val = resolve_consts(value, all_consts)
      cons(cons(name, resolved_val), resolve_const_values(rest, all_consts))
    }
  }
}

fn filter_const_forms(forms, acc) {
  match forms {
    nil -> reverse_list(acc, nil)
    cons(form, rest) -> {
      if pair?(form) && car(form) == 'const {
        filter_const_forms(rest, acc)
      } else {
        filter_const_forms(rest, cons(form, acc))
      }
    }
  }
}

// ============================================================
// Main compilation pipeline
// ============================================================

fn compile_code(ast) {
  let consts = collect_consts(ast, nil)
  let resolved_consts = resolve_const_values(consts, consts)
  let clean_ast = filter_const_forms(ast, nil)
  let final_ast = resolve_consts(clean_ast, resolved_consts)
  let b = buf.new()
  let p1 = pass1_register(final_ast, nil, 0)
  let fn_names_base = car(p1)
  let n_funcs = cdr(p1)
  let sym_result = collect_ast_list(final_ast, init_syms(), 42)
  let full_syms = car(sym_result)
  let fn_names = embed_syms(fn_names_base, full_syms)
  buf.push_byte(b, OP_JUMP())
  let jump_pos = buf.length(b)
  emit_u32(b, 0)
  let p2 = pass2_compile(final_ast, b, fn_names, n_funcs + 1, nil, 0, nil)
  let total_fns = car(p2)
  let fn_entries = car(cdr(p2))
  let fn_offsets = cdr(cdr(p2))
  let top_entry = buf.length(b)
  patch_u32(b, jump_pos, top_entry)
  let tl_result = compile_top_level(final_ast, b, fn_names, fn_entries, total_fns, 0)
  let has_top = car(tl_result)
  let final_fn_entries = car(cdr(tl_result))
  let final_total_fns = cdr(cdr(tl_result))
  if has_top == 0 {
    let main_fid = find_main_fn(fn_names)
    if main_fid >= 0 {
      buf.push_byte(b, OP_SPAWN_MAIN())
      emit_u32(b, main_fid)
    }
  }
  buf.push_byte(b, OP_PUSH_NIL())
  buf.push_byte(b, OP_HALT())
  cons(b, cons(final_total_fns, cons(n_funcs, cons(top_entry,
    cons(fn_offsets, cons(final_fn_entries, full_syms))))))
}

// ============================================================
// Serialize to .tabc
// ============================================================

fn serialize_syms(out, syms, idx, max_idx) {
  if idx < max_idx {
    let name = sym_find_by_idx(syms, idx)
    emit_u32(out, str.length(name))
    buf.push_string(out, name)
    serialize_syms(out, syms, idx + 1, max_idx)
  }
}

fn ser_fn_table(out, define_off, lambda_off, idx, total_fns, top_fn_id, top_off) {
  if idx < total_fns {
    if idx == top_fn_id {
      emit_u32(out, top_off)
    } else {
      emit_u32(out, find_fn_entry(define_off, lambda_off, idx))
    }
    ser_fn_table(out, define_off, lambda_off, idx + 1, total_fns, top_fn_id, top_off)
  }
}

fn copy_bytes(dest, src, pos, len) {
  if pos < len {
    buf.push_byte(dest, buf.get_byte(src, pos))
    copy_bytes(dest, src, pos + 1, len)
  }
}

fn serialize_tabc(info) {
  let b = car(info)
  let total_fns = car(cdr(info))
  let n_funcs = car(cdr(cdr(info)))
  let top_entry = car(cdr(cdr(cdr(info))))
  let fn_offsets = car(cdr(cdr(cdr(cdr(info)))))
  let fn_entries = car(cdr(cdr(cdr(cdr(cdr(info))))))
  let syms = cdr(cdr(cdr(cdr(cdr(cdr(info))))))
  let n_syms = sym_count(syms)
  let out = buf.new()
  buf.push_byte(out, 84)  // 'T'
  buf.push_byte(out, 65)  // 'A'
  buf.push_byte(out, 66)  // 'B'
  buf.push_byte(out, 67)  // 'C'
  emit_u32(out, 1)         // version
  emit_u32(out, n_syms)
  emit_u32(out, total_fns)
  emit_u32(out, n_funcs)
  emit_u32(out, buf.length(b))
  serialize_syms(out, syms, 0, n_syms)
  ser_fn_table(out, fn_offsets, fn_entries, 0, total_fns, n_funcs, top_entry)
  copy_bytes(out, b, 0, buf.length(b))
  out
}

// ============================================================
// Public API
// ============================================================

pub fn compile(ast) {
  let info = compile_code(ast)
  serialize_tabc(info)
}

pub fn compile_and_write(ast, out_path) {
  let out = compile(ast)
  buf.write_to(out, out_path)
}
