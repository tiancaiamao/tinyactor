// ============================================================
// Actor program tests (Test A–F)
// ============================================================

// Test A: spawn + send
// (define (main) (spawn (lambda (pid) (send pid 42))))
// expect: unit -> pid  (spawn returns pid)
fn test_a() {
  print("=== Test A: spawn + send ===")
  let prog = cons(
    cons('define, cons(cons('main, nil),
      cons(cons('spawn,
        cons(cons('lambda, cons(cons('pid, nil),
          cons(cons('send, cons('pid, cons(42, nil))), nil))), nil)), nil))),
    nil)
  let ip = infer_program(prog)
  let env = car(ip)
  let s = car(cdr(ip))
  let b = assq('main, env)
  let sch = cdr(b)
          print(type_format(sch, s))
}

// Test J: annotated function

