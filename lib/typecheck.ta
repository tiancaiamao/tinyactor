// Test L: generic recursive ADT
// type List(a) { Nil; Cons(a, List(a)) }
// (define (single x) (Cons x 'Nil))
// expect single: forall(a). a -> List(a)
// expect Nil: forall(a). List(a)
// expect Cons: forall(a). a -> List(a) -> List(a)
fn test_l() {
  print("=== Test L: generic ADT List ===")
  let prog = cons(
    cons('type, cons('List, cons(cons('a, nil),
      cons(cons('quote, cons('Nil, nil)),
      cons(cons('Cons, cons('a, cons(cons('List, cons('a, nil)), nil))), nil))))),
    cons(cons('define, cons(cons('single, cons('x, nil)),
      cons(cons('Cons, cons('x, cons(cons('quote, cons('Nil, nil)), nil))), nil))),
    nil))
  let ip = infer_program(prog)
  let env = car(ip)
  let s = car(cdr(ip))
  // single
  let bs = assq('single, env)
  print("single: ", type_format(cdr(bs), s))
  // Nil
  let bn = assq('Nil, env)
    print("Nil: ", type_format(cdr(bn), s))
  // Cons
  let bc = assq('Cons, env)
  print("Cons: ", type_format(cdr(bc), s))
}

// Test M: composite type annotations
// Source: fn length(lst: List(int)) -> int { ... }
//         fn unwrap(r: Result(int, string)) -> int { ... }
// AST: (type-sig length ((List int)) int)
//      (type-sig unwrap ((Result int string)) int)
fn test_m() {
  print("=== Test M: composite annotation ===")
  let prog = cons(
    cons('type-sig, cons('length,
      cons(cons(cons('List, cons('int, nil)), nil),
        cons('int, nil)))),
    cons(
      cons('type-sig, cons('unwrap,
        cons(cons(cons('Result, cons('int, cons('string, nil))), nil),
          cons('int, nil)))),
      cons(
        cons('define, cons(cons('length, cons('lst, nil)),
          cons(0, nil))),
        cons(
          cons('define, cons(cons('unwrap, cons('r, nil)),
            cons(0, nil))),
          nil))))
  let ip = infer_program(prog)
  let env = car(ip)
  let s = car(cdr(ip))
  let bl = assq('length, env)
  print("length: ", type_format(cdr(bl), s))
  let bu = assq('unwrap, env)
  print("unwrap: ", type_format(cdr(bu), s))
}